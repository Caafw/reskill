<main>\
\
  <!-- SCREEN 1: SUBJECT -->\
  <div class="screen active" id="screen-1">\
    <div class="section-rule">Subject &amp; Domain</div>\
    <h1>What would you like<br>to <em>teach or learn?</em></h1>\
    <p class="lead">Select from the subjects below to generate a free course outline. Want a different subject, or training built on your own documents? CAAFW builds it for you.</p>\
