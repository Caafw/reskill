function startGeneration()\{\
  // Show email capture modal first, then generate\
  showEmailCapture();\
\}\
function startGenerationDirect()\{\
  // Called if email already captured this session\
  proceedWithGeneration();\
\}\
function proceedWithGeneration()\{\
  document.getElementById('ls-role').textContent=S.role==='Instructor'?'Instructor':'Learner';\
  const steps=['ls-1','ls-2','ls-3','ls-4','ls-5'];\
  let i=0;\
  document.querySelectorAll('.log-line').forEach(s=>s.classList.remove('show','done'));\
  const iv=setInterval(()=>\{\
    if(i>0)document.getElementById(steps[i-1]).classList.add('done');\
    if(i<steps.length)\{document.getElementById(steps[i]).classList.add('show');i++;\}\
    else\{clearInterval(iv);callClaudeOutline();\}\
  \},650);\
\}\
\
async function callClaudeOutline()\{\
  // OUTPUT: JSON outline. Calibrated max_tokens=800 covers 8 mods x 5 lessons comfortably.\
  const mc=S.modules==='auto'?(S.level==='Beginner'?5:S.level==='Intermediate'?6:8):parseInt(S.modules);\
  const lc=\{'Beginner':'3-4','Intermediate':'4-5','Advanced':'5-6'\}[S.level];\
  // Schema-first prompt: no verbose English explanations of fields \'97 saves ~120 input tokens\
  const p=`JSON outline. Topic:"$\{S.topic\}" Role:$\{S.role\} Level:$\{S.level\} `+\
    `Audience:$\{S.audience||'general'\} Modules:$\{mc\} LessonsPerMod:$\{lc\} `+\
    (S.goals&&S.role==='Designer'?`SourceDoc:"$\{S.goals.substring(0,500)\}" `:(S.goals?`Goals:"$\{S.goals\}" `:''))+\
    `Types:video|reading|quiz|activity Dur:video=8-15m,reading=10-20m,quiz=5-10m,activity=15-30m `+\
    `Overview:$\{S.role==='Instructor'?'trainer key teaching points':S.role==='Designer'?'process step or policy rule from source document':'learner benefit'\}\
`+\
    `\{"courseTitle":"","tagline":"","totalDuration":"","outcomes":["","","",""],`+\
    `"modules":[\{"title":"","overview":"","duration":"","lessons":[\{"id":"","name":"","type":"","duration":""\}],"assessment":""\}]\}`;\
  try\{\
    const data=await callAPI(\{model:'claude-sonnet-4-6',max_tokens:800,system:'JSON only. No markdown.',messages:[\{role:'user',content:p\}]\});\
    let raw=data.content.find(b=>b.type==='text')?.text||'';\
    raw=raw.replace(/```json|```/g,'').trim();\
    S.courseData=JSON.parse(raw);\
  \}catch(e)\{\
    console.error('Outline API error:',e);\
    // Show error in loading screen before falling back\
    const note=document.getElementById('ls-5');\
    if(note)\{note.textContent='Error: '+e.message+' \'97 showing template outline instead. Check browser console for details.';note.style.color='#8b1a1a';\}\
    if(!isClaudeAi()&&!getApiKey())\{\
      document.getElementById('api-key-bar').style.display='flex';\
      document.getElementById('api-key-status').textContent='API key needed to generate AI content. Enter your key above and try again.';\
      document.getElementById('api-key-status').style.display='block';\
      document.getElementById('api-key-status').style.color='#8b1a1a';\
    \}\
    S.courseData=buildFallback();\
  \}\
  renderCourse();\
\}\
\
function buildFallback()\{\
  const n=S.modules==='auto'?(S.level==='Beginner'?5:S.level==='Intermediate'?6:8):parseInt(S.modules);\
  const titles=['Foundations and Core Concepts','Key Principles in Practice','Methods and Techniques','Applied Case Studies','Advanced Applications','Strategy and Integration','Mastery and Further Study'];\
  const modules=[];\
  for(let i=0;i<n;i++)\{\
    const lc=S.level==='Beginner'?3:S.level==='Intermediate'?4:5;\
    const lessons=[];\
    const types=['video','reading','activity','quiz','reading'];\
    const durs=['10 min','14 min','20 min','8 min','12 min'];\
    for(let j=0;j<lc;j++)lessons.push(\{id:`m$\{i+1\}l$\{j+1\}`,name:`$\{['Introduction to','Exploring','Applying','Practising','Synthesis of'][j]||'Study of'\} $\{S.topic\}`,type:types[j],duration:durs[j]\});\
    modules.push(\{title:titles[i]||`Part $\{i+1\}`,overview:`This module addresses $\{(titles[i]||'core content').toLowerCase()\} within the study of $\{S.topic\}.`,duration:S.level==='Beginner'?'45 min':S.level==='Intermediate'?'60 min':'90 min',lessons,assessment:S.level==='Beginner'?'Five-question knowledge assessment':S.level==='Intermediate'?'Applied exercise using module concepts':'Analytical assignment or case study'\});\
  \}\
  return\{courseTitle:S.topic,tagline:`A $\{S.level.toLowerCase()\}-level course in $\{S.topic\}.`,totalDuration:S.level==='Beginner'?'4\'965 hrs':S.level==='Intermediate'?'6\'968 hrs':'10\'9612 hrs',outcomes:[`Understand the core principles of $\{S.topic\}`,`Apply key concepts and methods in context`,`Evaluate different approaches and frameworks`,`Demonstrate competence and fluency in the subject`],modules\};\
\}\
