    return;\
  \}\
  if(n===3&&!S.role)\{alert('Please select your role \'97 Learner, Instructor, or Instructional Designer.');return;\}\
  if(n===4&&!S.level)\{alert('Please select a knowledge level.');return;\}\
  if(n===5&&!S.format)\{alert('Please choose a content format.');return;\}\
  if(!S.topic) S.topic=document.getElementById('topic-input').value.trim();\
