          <div class="chip" onclick="selectChip(this,'Newtonian Mechanics')">Newtonian Mechanics</div>\
          <div class="chip" onclick="selectChip(this,'Marketing Fundamentals')">Marketing Fundamentals</div>\
          <div class="chip" onclick="selectChip(this,'Creative Writing')">Creative Writing</div>\
          <div class="chip" onclick="selectChip(this,'Public Speaking')">Public Speaking</div>\
          <div class="chip" onclick="selectChip(this,'Leadership &amp; Management')">Leadership &amp; Management</div>\
          <div class="chip" onclick="selectChip(this,'Prompt Engineering')">Prompt Engineering</div>\
