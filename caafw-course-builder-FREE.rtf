          <div class="chip" onclick="selectChip(this,'AI Fundamentals for Business')">AI Fundamentals for Business</div>\
          <div class="chip" onclick="selectChip(this,'Python for Beginners')">Python for Beginners</div>\
          <div class="chip" onclick="selectChip(this,'Financial Literacy')">Financial Literacy</div>\
          <div class="chip" onclick="selectChip(this,'Project Management')">Project Management</div>\
