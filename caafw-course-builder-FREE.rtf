      try\{\
        const data=await callAPI(\{model:'claude-sonnet-4-6',max_tokens:4000,system:systemPrompt,messages:[\{role:'user',content:isDeepDesigner?designerPrompt:isInstructor?instructorPrompt:learnerPrompt\}]\});\
        let raw=data.content.find(b=>b.type==='text')?.text||'';\
        raw=raw.replace(/```html?|```/gi,'').trim();\
        lessonContents.push(\{lesson,content:raw\});\
      \}catch(e)\{\
        console.error('Deep API error:',e);\
        const errMsg=e.message||'Unknown error';\
        const isAuth=errMsg.includes('401')||errMsg.includes('authentication')||errMsg.includes('API key');\
        const errHtml=isAuth||(!isClaudeAi()&&!getApiKey())\
          ?'<p style="color:#8b1a1a"><strong>API key required.</strong> Enter your Anthropic API key at the top of the page and try generating again.</p>'\
          :'<p style="color:#7a7a7a">Could not load content: '+errMsg+'</p>';\
        lessonContents.push(\{lesson,content:errHtml\});\
        if(isAuth||(!isClaudeAi()&&!getApiKey()))document.getElementById('api-key-bar').style.display='flex';\
      \}\
      await new Promise(r=>setTimeout(r,300));\
    \}\
    allDeepContent.push(\{mod,lessons:lessonContents\});\
  \}\
  document.getElementById('deep-progress-bar').style.width='100%';\
  document.getElementById('deep-progress-label').textContent='Complete \'97 rendering course\'85';\
  await new Promise(r=>setTimeout(r,400));\
  renderDeepCourse(allDeepContent);\
  btn.textContent='Complete Course Generated';\
\}\
\
function renderDeepCourse(content)\{\
  const isInstructor=S.role==='Instructor';\
  let html=`<div class="deep-output-wrap">\
    <div class="deep-edition-label">CAAFW Course Builder &mdash; $\{S.role==='Designer'?'Process Designer Edition':isInstructor?'Instructor Edition':'Learner Edition'\}</div>\
    <div class="deep-course-title">$\{S.courseData.courseTitle\}</div>`;\
  content.forEach((\{mod,lessons\},mi)=>\{\
    html+=`<div class="deep-mod-block">\
      <div class="deep-mod-heading">Module $\{String(mi+1).padStart(2,'0')\}</div>\
      <div class="deep-mod-title">$\{mod.title\}</div>`;\
    lessons.forEach((\{lesson,content:lc\},li)=>\{\
      html+=`<div class="deep-lesson-block">\
        <div class="deep-lesson-heading">Lesson $\{li+1\} &nbsp;&middot;&nbsp; $\{lesson.duration\}</div>\
        <div class="deep-lesson-title">$\{lesson.name\}</div>\
        <div class="deep-content">$\{lc\}</div>\
        $\{S.role==='Designer'?`<div class="trainer-aside" style="margin-top:16px"><div class="trainer-aside-label">Source Fidelity</div>Review this content against your current procedures before deployment. If your process has changed since this document was written, update accordingly.</div>`:isInstructor?`<div class="trainer-aside" style="margin-top:16px"><div class="trainer-aside-label">Instructor Reminder</div>Adapt all examples to your learners' discipline and context. Pause after each section for questions.</div>`:''\}\
      </div>`;\
    \});\
    html+=`<div class="deep-assessment-block"><strong>Module Assessment</strong>$\{mod.assessment\}</div></div>`;\
  \});\
  html+=`<div class="footer-colophon" style="margin-top:32px">\
    This course was generated by the CAAFW Course Builder. For a formatted document, hosted delivery, or learner certification, write to\
    <a href="mailto:hello@caafw.org">hello@caafw.org</a> or visit\
    <a href="https://www.caafw.org/Reskill" target="_blank">caafw.org/Reskill</a>.\
  </div></div>`;\
  document.getElementById('deep-output').innerHTML=html;\
  document.getElementById('deep-output').scrollIntoView(\{behavior:'smooth',block:'start'\});\
\}\
\
function toggleModule(idx)\{document.getElementById('mod-'+idx).classList.toggle('open');\}\
\
function resetBuilder()\{\
  Object.assign(S,\{topic:'',role:'',level:'',format:'',audience:'',goals:'',modules:'auto',courseData:null\});\
  ['topic-input','audience-input','goals-input'].forEach(id=>document.getElementById(id).value='');\
  document.getElementById('modules-select').value='auto';\
  document.querySelectorAll('.chip,.sel-card').forEach(c=>c.classList.remove('selected'));\
  document.querySelectorAll('.log-line').forEach(s=>s.classList.remove('show','done'));\
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));\
  document.getElementById('screen-1').classList.add('active');\
  updateSteps(1);\
\}\
