        <div class="chip-row">\
          <div class="chip chip--featured chip--enquiry" onclick="showProcessEnquiry('Claims Handling Process')">Claims Handling Process</div>\
          <div class="chip chip--featured chip--enquiry" onclick="showProcessEnquiry('Customer Service Standards')">Customer Service Standards</div>\
          <div class="chip chip--featured chip--enquiry" onclick="showProcessEnquiry('Compliance &amp; Regulatory Training')">Compliance &amp; Regulatory Training</div>\
          <div class="chip chip--featured chip--enquiry" onclick="showProcessEnquiry('Onboarding &amp; Induction')">Onboarding &amp; Induction</div>\
          <div class="chip chip--featured chip--enquiry" onclick="showProcessEnquiry('Health &amp; Safety Procedures')">Health &amp; Safety Procedures</div>\
        </div>\
      </div>\
