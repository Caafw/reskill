    else if(S.role==='Designer')\{lvlH.innerHTML='What level are<br>your <em>staff?</em>';lvlL.textContent='Set the level of the staff being trained. We will adapt the complexity of the training output accordingly.';\}\
    else\{lvlH.innerHTML='What is your<br><em>starting point?</em>';lvlL.textContent='We will adapt depth, language, and complexity to your starting point.';\}\
  \}\
  if(n===5)\{\
    const aLbl=document.getElementById('audience-label');\
