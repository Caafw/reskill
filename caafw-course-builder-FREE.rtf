    \} else if(S.role==='Instructor')\{\
      aLbl.textContent='Who are your learners?';\
      aIn.placeholder='e.g. marketing managers, postgraduate students, small business owners\'85';\
      gLbl.textContent='Key learning goals';\
      gIn.placeholder='e.g. Learners should be able to apply these skills in professional practice within two weeks\'85';\
    \} else \{\
      aLbl.textContent='Who is this course for?';\
      aIn.placeholder='e.g. marketing managers, postgraduate students, small business owners\'85';\
      gLbl.textContent='Key learning goals';\
      gIn.placeholder='e.g. Learners should be able to apply these skills in professional practice within two weeks\'85';\
    \}\
  \}\
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));\
  document.getElementById('screen-'+n).classList.add('active');\
