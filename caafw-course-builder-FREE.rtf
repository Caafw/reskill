<script>\
\
// \uc0\u9472 \u9472  API KEY MANAGEMENT \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \
let _apiKey = '';\
\
function saveApiKey()\{\
  const k = document.getElementById('api-key-input').value.trim();\
  if(!k.startsWith('sk-ant-'))\{\
    document.getElementById('api-key-status').textContent = 'Key should start with sk-ant- \'97 please check and try again.';\
    document.getElementById('api-key-status').style.display = 'block';\
    document.getElementById('api-key-status').style.color = '#8b1a1a';\
    return;\
  \}\
  _apiKey = k;\
  document.getElementById('api-key-status').textContent = 'Key saved for this session. You can now generate courses.';\
  document.getElementById('api-key-status').style.display = 'block';\
  document.getElementById('api-key-status').style.color = '#002147';\
  document.getElementById('api-key-input').value = '';\
\}\
\
// Detect if running inside Claude.ai (no key needed) or standalone (key needed)\
function isClaudeAi()\{\
  return window.location.hostname.includes('claude.ai') || \
         window.location.protocol === 'blob:' ||\
         window.location.hostname === '';\
\}\
\
function getApiKey()\{\
  return _apiKey || null;\
\}\
\
function buildHeaders()\{\
  const key = getApiKey();\
  // No explicit key: rely entirely on the platform proxy (Claude.ai handles auth)\
  // With explicit key: send full direct-browser auth headers for standalone use\
  if(!key)\{\
    return \{'Content-Type':'application/json'\};\
  \}\
  return \{\
    'Content-Type':'application/json',\
    'x-api-key': key,\
    'anthropic-version':'2023-06-01',\
    'anthropic-dangerous-direct-browser-access':'true'\
  \};\
\}\
\
// Show key bar if not in Claude.ai and no key set\
window.addEventListener('DOMContentLoaded', async ()=>\{\
  // Quick connectivity test \'97 tiny request to check API is reachable\
  try \{\
    const test = await fetch('https://api.anthropic.com/v1/messages', \{\
      method: 'POST',\
      headers: buildHeaders(),\
      body: JSON.stringify(\{\
        model: 'claude-sonnet-4-6',\
        max_tokens: 5,\
        messages: [\{role:'user', content:'hi'\}]\
      \})\
    \});\
    const txt = await test.text();\
    console.log('API connectivity test \'97 status:', test.status, 'response:', txt.substring(0,150));\
    if(test.status === 401 || test.status === 403)\{\
      // Auth error \'97 needs key\
      document.getElementById('api-key-bar').style.display = 'flex';\
      document.getElementById('api-key-status').textContent = 'API key required to use this tool outside Claude.ai.';\
      document.getElementById('api-key-status').style.display = 'block';\
      document.getElementById('api-key-status').style.color = '#8b1a1a';\
    \}\
    // 200 or other \'97 API is reachable, all good\
  \} catch(e) \{\
    console.warn('API connectivity test failed:', e.message);\
    // Network blocked \'97 show key bar with explanation\
    document.getElementById('api-key-bar').style.display = 'flex';\
    document.getElementById('api-key-status').textContent = 'Could not reach Anthropic API ('+e.message+'). If you are using this outside Claude.ai, enter your API key above.';\
    document.getElementById('api-key-status').style.display = 'block';\
    document.getElementById('api-key-status').style.color = '#8b1a1a';\
  \}\
\});\
\
// \uc0\u9472 \u9472  API CALL WRAPPER with proper error surfacing \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \
async function callAPI(body)\{\
  let res;\
  try \{\
    res = await fetch('https://api.anthropic.com/v1/messages', \{\
      method: 'POST',\
      headers: buildHeaders(),\
      body: JSON.stringify(body)\
    \});\
  \} catch(networkErr) \{\
    // fetch() itself failed \'97 likely CSP block or no network\
    console.error('Network error:', networkErr);\
    throw new Error('Network error \'97 check your connection or API key setup');\
  \}\
  // Read response as text first so we can handle non-JSON responses\
  let text;\
  try \{ text = await res.text(); \} catch(e) \{ throw new Error('Could not read API response'); \}\
  // Log full response for debugging\
  console.log('API status:', res.status, 'body:', text.substring(0,200));\
  let parsed;\
  try \{ parsed = JSON.parse(text); \} catch(e) \{\
    throw new Error('API returned non-JSON (status '+res.status+'): '+text.substring(0,100));\
  \}\
  if(!res.ok)\{\
    const msg = parsed?.error?.message || 'HTTP '+res.status;\
    throw new Error(msg);\
  \}\
  return parsed;\
\}\
